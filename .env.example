# Copie este arquivo para .env e preencha o que for usar

# --- Chaves de API dos provedores ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Provider open-source (endpoint compatível com API da OpenAI: Ollama, vLLM, LM Studio, etc.) ---
OPENSOURCE_BASE_URL=http://localhost:11434/v1
OPENSOURCE_MODEL=llama3
OPENSOURCE_API_KEY=not-needed

# --- Provider e modelo default do sistema ---
DEFAULT_PROVIDER=claude

# --- Banco de dados estruturado ---
# SQLite local (default, funciona sem infraestrutura):
DATABASE_URL=sqlite:///./pie.db
# Para Postgres, use algo como:
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/pie

# --- Memória semântica (ChromaDB, persistência local em disco) ---
CHROMA_PATH=./pie_chroma